# Markdown Frontmatter Engine - 环境配置
# 复制此文件为 .env 放置在 skill 根目录下

# ============================================================
# 字段配置：逗号分隔，指定 skill 默认只处理哪些字段
# 留空或不写此行 = 全量（处理 schema/ 下所有字段）
# 对话中明确指定字段时，此配置被对话指定覆盖
# ============================================================
SCHEMA_FIELDS=title,tags,domain
